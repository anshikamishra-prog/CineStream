# Enforce LF endings for code files
*.js     text eol=lf
*.jsx    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.css    text eol=lf
*.html   text eol=lf

# Keep shell scripts consistent
*.sh     text eol=lf

# Windows batch files should use CRLF
*.bat    text eol=crlf

# Mark binary files (no line ending conversion)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.svg    binary
*.ico    binary

# Docker and config files
Dockerfile* text eol=lf
*.env       text eol=lf
