{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*":            ["src/*"],
      "@components/*":  ["src/components/*"],
      "@pages/*":       ["src/pages/*"],
      "@hooks/*":       ["src/hooks/*"],
      "@contexts/*":    ["src/contexts/*"],
      "@services/*":    ["src/services/*"],
      "@utils/*":       ["src/utils/*"],
      "@store/*":       ["src/store/*"],
      "@features/*":    ["src/features/*"],
      "@api/*":         ["src/api/*"],
      "@routes/*":      ["src/routes/*"]
    },
    "checkJs": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "target": "ESNext",
    "strict": false,
    "noEmit": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
